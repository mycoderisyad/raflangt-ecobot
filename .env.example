# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Admin User Configuration
ADMIN_PHONE_NUMBERS=+6281234567890,+6281234567891
KOORDINATOR_PHONE_NUMBERS=+6281234567892,+6281234567893

# Lunos.tech AI Configuration (RECOMMENDED)
LUNOS_API_KEY=
LUNOS_BASE_URL=https://api.lunos.tech/v1
LUNOS_APP_ID=ecobot-whatsapp-v1.0
LUNOS_TEXT_MODEL=openai/gpt-4o-mini
LUNOS_VISION_MODEL=openai/gpt-4o

