# ============================================
# EcoBot v2 — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
ENVIRONMENT=development          # development | production
APP_NAME=EcoBot
APP_VERSION=2.0.0
PORT=5000
TIMEZONE=Asia/Jakarta
VILLAGE_NAME=
VILLAGE_COORDINATES=
REGISTRATION_MODE=auto           # auto | manual

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecobot
# Docker overrides this via docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecobot

# --- AI Provider ---
AI_PROVIDER=gemini               # gemini | openai
AI_API_KEY=
AI_MODEL=gemini-2.0-flash        # or gpt-4o-mini for openai
AI_BASE_URL=                     # leave blank for defaults

# --- WhatsApp (WAHA) ---
WHATSAPP_ENABLED=true
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION_NAME=default

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=EcoBot <noreply@ecobot.id>
EMAIL_TO=admin@example.com

# --- Role management (WhatsApp — phone numbers) ---
ADMIN_PHONE_NUMBERS=628xxx       # comma-separated
COORDINATOR_PHONE_NUMBERS=

# --- Role management (Telegram — usernames, tanpa @) ---
ADMIN_TELEGRAM_USERNAMES=
COORDINATOR_TELEGRAM_USERNAMES=

# --- Admin Panel ---
ADMIN_PANEL_SECRET_KEY=change-me-to-something-random
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=admin
