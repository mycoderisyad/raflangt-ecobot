# ============================================
# EcoBot v2 — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
# development | production
ENVIRONMENT=development
APP_NAME=EcoBot
APP_VERSION=2.0.0
PORT=8000
TIMEZONE=Asia/Jakarta
VILLAGE_NAME=
VILLAGE_COORDINATES=
# auto | manual
REGISTRATION_MODE=auto

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecobot
# Docker overrides this via docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecobot

# --- AI Provider ---
# gemini | openai
AI_PROVIDER=gemini
AI_API_KEY=
# gemini-2.0-flash, gemini-2.5-flash-lite, gpt-4o-mini, etc.
AI_MODEL=gemini-2.0-flash
# Leave blank for defaults (Gemini or OpenAI auto-detected)
AI_BASE_URL=

# --- WhatsApp (WAHA) ---
WHATSAPP_ENABLED=true
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION_NAME=default

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=EcoBot <noreply@ecobot.id>
EMAIL_TO=admin@example.com

# --- Role management (WhatsApp — phone numbers) ---
# comma-separated
ADMIN_PHONE_NUMBERS=628xxx
COORDINATOR_PHONE_NUMBERS=

# --- Role management (Telegram — usernames, tanpa @) ---
ADMIN_TELEGRAM_USERNAMES=
COORDINATOR_TELEGRAM_USERNAMES=

# --- Admin Panel ---
ADMIN_PANEL_SECRET_KEY=change-me-to-something-random
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=admin
