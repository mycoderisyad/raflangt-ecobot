# ============================================================================
# EcoBot Configuration Template
# Copy this file to .env and configure with your actual values
# ============================================================================

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================
# Environment: development, production
ENVIRONMENT=production

# Application port (5000 for dev, 8000 for production)
PORT=8000

# Debug mode (automatically set based on environment, but can be overridden)
# DEBUG=false

# ============================================================================
# WHATSAPP API CONFIGURATION (WAHA)
# ============================================================================
# WAHA (WhatsApp HTTP API) server URL
WAHA_BASE_URL=https://your-waha-instance.com/api

# WAHA API key for authentication
WAHA_API_KEY=your_waha_api_key_here

# WhatsApp session name
WAHA_SESSION_NAME=ecobot_session

# Webhook URL where WAHA will send messages
WEBHOOK_URL=https://your-domain.com/webhook

# ============================================================================
# USER ROLES CONFIGURATION
# ============================================================================
# Admin phone numbers (comma-separated, include country code)
ADMIN_PHONE_NUMBERS=+6281234567890,+6281234567891

# Coordinator phone numbers (comma-separated, include country code)
KOORDINATOR_PHONE_NUMBERS=+6281234567892,+6281234567893

# ============================================================================
# AI SERVICES CONFIGURATION
# ============================================================================
# Enable AI features (true/false)
AI_ENABLED=true

# Lunos.tech AI service configuration
LUNOS_API_KEY=your_lunos_api_key_here
LUNOS_BASE_URL=https://api.lunos.tech/v1
LUNOS_TEXT_MODEL=openai/gpt-4o-mini

# Unli.dev image analysis service
UNLI_API_KEY=your_unli_api_key_here
UNLI_BASE_URL=https://api.unli.dev/v1

# ============================================================================
# MAPS INTEGRATION
# ============================================================================
# Enable maps features (true/false)
MAPS_ENABLED=true

# Google Maps API configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_STATIC_URL=https://maps.googleapis.com/maps/api/staticmap
GOOGLE_MAPS_DIRECTIONS_URL=https://www.google.com/maps/dir/
GOOGLE_MAPS_VIEW_URL=https://www.google.com/maps/@
GOOGLE_MAPS_MOCK_TEMPLATE=https://maps.google.com/maps?q={lat},{lng}&z=15

# ============================================================================
# EMAIL SERVICE CONFIGURATION
# ============================================================================
# Mailry.co email service configuration
MAILRY_API_KEY=your_mailry_api_key_here
MAILRY_BASE_URL=https://api.mailry.co/ext
MAILRY_FROM_EMAIL=noreply@yourdomain.com
MAILRY_TO_EMAIL=admin@yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite database path
DATABASE_PATH=database/ecobot.db

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Application metadata
APP_NAME=EcoBot
APP_VERSION=1.0.0

# Security settings
SECRET_KEY=your-super-secret-key-change-this-in-production
ADMIN_PANEL_SECRET_KEY=your-admin-panel-secret-key

# Admin Panel Configuration
ADMIN_PANEL_PORT=3001
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-this-secure-password

# File upload settings
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif
MAX_IMAGE_SIZE_MB=5

# ============================================================================
# VILLAGE/COMMUNITY SETTINGS
# ============================================================================
# Village or community name
VILLAGE_NAME=your_village_name_here

# Village coordinates (latitude,longitude)
VILLAGE_COORDINATES=-6.2088,106.8456

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================
# 1. Change all default passwords and secret keys
# 2. Use strong, unique API keys for all external services
# 3. Configure proper domain names and HTTPS URLs
# 4. Set ENVIRONMENT=production for production deployment
# 5. Ensure database path is accessible and has proper permissions
# 6. Configure proper logging and monitoring
# ============================================================================
