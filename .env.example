# ============================================================================
# EcoBot Configuration (.env) - CLEANED
# ============================================================================

# ENVIRONMENT SETTINGS
ENVIRONMENT=production
PORT=8000

# WHATSAPP API CONFIGURATION (WAHA)
WAHA_BASE_URL=
WAHA_API_KEY=
WAHA_SESSION_NAME=default
WEBHOOK_URL=

# USER ROLES
ADMIN_PHONE_NUMBERS=
KOORDINATOR_PHONE_NUMBERS=

# AI SERVICES
AI_ENABLED=true

# Lunos.tech (Text AI)
LUNOS_API_KEY=
LUNOS_BASE_URL=https://api.lunos.tech/v1
LUNOS_TEXT_MODEL=google/gemini-2.5-flash
LUNOS_AGENT_MODEL=google/gemini-2.5-flash

# Unli.dev (Image Analysis)
UNLI_API_KEY=UNLI-IMPHNEN
UNLI_BASE_URL=https://api.unli.dev/v1
UNLI_MODEL=auto

# MAPS
MAPS_ENABLED=false
GOOGLE_MAPS_API_KEY=__REPLACE_WITH_GOOGLE_MAPS_API_KEY__
GOOGLE_MAPS_STATIC_URL=https://maps.googleapis.com/maps/api/staticmap
GOOGLE_MAPS_DIRECTIONS_URL=https://www.google.com/maps/dir/
GOOGLE_MAPS_VIEW_URL=https://www.google.com/maps/@
GOOGLE_MAPS_MOCK_TEMPLATE=https://maps.google.com/maps?q={lat},{lng}&z=15

# EMAIL (Mailry)
MAILRY_API_KEY=__REPLACE_WITH_MAILRY_API_KEY__
MAILRY_BASE_URL=https://api.mailry.co/ext
MAILRY_FROM_EMAIL=noreply@yourdomain.com
MAILRY_TO_EMAIL=admin@yourdomain.com

# DATABASE
DATABASE_PATH=database/ecobot.db

# APP SETTINGS
APP_NAME=EcoBot
APP_VERSION=1.0.0
SECRET_KEY=__CHANGE_ME_STRONG_RANDOM__
ADMIN_PANEL_SECRET_KEY=__CHANGE_ME_STRONG_RANDOM__

# Admin Panel
ADMIN_PANEL_PORT=3001
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=admin

# Uploads
SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif
MAX_IMAGE_SIZE_MB=5

# VILLAGE/COMMUNITY
VILLAGE_NAME=your_village_name_here
VILLAGE_COORDINATES=-6.2088,106.8456
