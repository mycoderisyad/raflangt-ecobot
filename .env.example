GEMINI_MODEL=
GEMINI_BASE_URL=

# Anthropic Claude Configuration (Legacy)
CLAUDE_API_KEY=
CLAUDE_MODEL=
CLAUDE_BASE_URL=

# Groq Configuration (Legacy)
